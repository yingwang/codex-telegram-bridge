TELEGRAM_BOT_TOKEN=123456:replace_me

# Comma-separated numeric Telegram chat IDs. Leave empty only for first-run
# discovery, then send /id to the bot and paste the returned ID here.
TELEGRAM_ALLOWED_CHAT_IDS=

# Where Codex should run. Keep this narrow.
CODEX_WORKDIR=/absolute/path/to/your/workspace
CODEX_BIN=codex
CODEX_SANDBOX=workspace-write
CODEX_TIMEOUT_SECONDS=1200

# Set by scripts/run_current_session.sh at runtime. Do not put this in a shared/global shell profile.
# CODEX_BIND_CURRENT_SESSION=1

# Alternative: bind Telegram to one explicit Codex session/thread id.
# CODEX_RESUME_SESSION=your-codex-thread-id

# Optional: require messages to start with /codex before running Codex.
TELEGRAM_REQUIRE_CODEX_PREFIX=0

# Optional: write Telegram inbound/outbound records to private local inbox files.
TELEGRAM_INBOX_ENABLED=1
# TELEGRAM_INBOX_PATH=~/.codex/channels/telegram/inbox.md
# TELEGRAM_INBOX_JSONL_PATH=~/.codex/channels/telegram/inbox.jsonl

# Optional: persistent Telegram persona and automatic local memory.
TELEGRAM_PERSONA_ENABLED=1
# TELEGRAM_PERSONA_PATH=~/.codex/memories/telegram-persona.md
TELEGRAM_MEMORY_ENABLED=1
# TELEGRAM_MEMORY_JSONL_PATH=~/.codex/memories/telegram-memory.jsonl
TELEGRAM_MEMORY_RECENT_EVENTS=12
TELEGRAM_MEMORY_MAX_CHARS=8000
